DATABASE_URL="postgresql://user:password@localhost:5432/hone_dev"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development

# Redis — BullMQ job queues (run: docker compose up redis -d)
REDIS_URL=redis://localhost:6379

# AWS S3 — file uploads (presigned URLs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# Resend email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@honefitness.com
EMAIL_FROM_NAME=Hone
APP_WEB_URL=http://localhost:3000
APP_ADMIN_URL=http://localhost:3002

# NVIDIA NIM — AI workout generation (free tier: https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
AI_DAILY_LIMIT=5
