{
  "name": "hone",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:api": "turbo run dev --filter=@hone/api",
    "dev:web": "turbo run dev --filter=@hone/web",
    "dev:admin": "turbo run dev --filter=@hone/admin",
    "db:generate": "pnpm --filter @hone/database db:generate",
    "db:migrate": "pnpm --filter @hone/database db:migrate",
    "db:studio": "pnpm --filter @hone/database db:studio",
    "db:seed": "pnpm --filter @hone/database db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
